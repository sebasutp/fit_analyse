# Frontend Environment Variables Example

# API Configuration
VITE_BACKEND_URL=http://localhost:8082 # URL where the backend API is accessible

# External Authentication Configuration (Optional)
# This should match the external service used by the backend
VITE_EXTERNAL_LOGIN_URL=https://auth.example.com/login # URL to redirect users for external login

# UI Configuration
VITE_ACTIVITY_PAGE_LIMIT=10 # Number of activities to display per page in the activity list
