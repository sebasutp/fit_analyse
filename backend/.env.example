# Backend Environment Variables Example

# Server Configuration
PORT=8082 # Port the FastAPI server will listen on
TOKEN_TIMEOUT=30 # JWT token expiration time in minutes

# Database Configuration
DB_URL=sqlite:///database.db # Database connection string (e.g., sqlite:///database.db or postgresql://user:pass@host/db)
DB_ECHO=False # Set to True to enable SQLAlchemy SQL logging

# Security & Authentication
JWT_SECRET=your_super_secret_key_here # Secret key for signing JWT tokens. Change this to a random string!
JWT_ALGORITHM=HS256 # Algorithm used for JWT signing

# External Authentication (Optional)
# If EXTERNAL_AUTH_ENDPOINT is set, the app will show an "External Login" option
# EXTERNAL_AUTH_ENDPOINT=https://auth.example.com/api/me # URL to validate external tokens and get user info
# EXTERNAL_AUTH_REQ_SCOPE=app:access # Required scope that must be present in the external user's scope list

# Activity Search Configuration
SEARCH_MATCH_THRESHOLD=75 # Fuzzy match threshold (0-100) for activity search. Higher is stricter.

# File Parsing Configuration
FIT_PARSE_GO_EXECUTABLE=./bin/fit_parser # Path to the Go binary used for fast FIT file processing
TRIGGER_FIT_RECOMPUTATION_BEFORE=2024-01-01 # Force recomputation of FIT files processed before this date

# Stats & Analysis Configuration
POWER_CURVE_CRON_FREQUENCY_HOURS=24 # How often to recompute power curves for all users
POWER_CURVE_PERIODS=3,6,12 # Comma-separated months for power curve filtering options

# UI/Display Configuration
CHART_POINTS_LIMIT=1000 # Maximum number of data points to send for charts to maintain performance
STATIC_MAP_W=400 # Width of generated static maps
STATIC_MAP_H=300 # Height of generated static maps
